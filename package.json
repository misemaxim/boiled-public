{
  "name": "boiled",
  "version": "0.0.1",
  "description": "cartography notepad",
  "main": "index.js",
  "scripts": {
    "build": "clear && rm -rf build && npm run build-browser && npm run build-server",
    "start": "nodemon",
    "docs": "npx docsify serve ./docs --port 9001",
    "test-jest": "clear && npx jest",
    "test-cypress": "clear && npx cypress open",
    "build-base": "clear && rm -rf build && webpack --mode production --config ./webpack.config.ts --progress && webpack --mode production --config ./src/server/build.ts --progress && npx ts-node dev/extract-server-modules.ts && npx ts-node dev/extract-licenses.ts",
    "build-desktop-win": "npm run build-base && npx ts-node dev/bundle-node.ts --os win && npx ts-node dev/build-archive.ts --os win",
    "build-desktop-linux": "npm run build-base && npx ts-node dev/bundle-node.ts --os linux && npx ts-node dev/build-archive.ts --os linux"
  },
